
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Default deny all access to prevent unintended access.
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Avatars
    // - Authenticated users can write to their own avatar folder.
    // - Anyone can read avatars (e.g., for displaying profile pictures).
    match /avatars/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read;
    }

    // Allow authenticated users to write to their own video folder.
    // The path is /user-videos/{userId}/{videoId}
    // This rule ensures that a user can only upload to their own directory.
    match /user-videos/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
      // Allow general read access for displaying videos in the app.
      allow read; 
    }

    // Allow authenticated users to read their own analysis result files.
    // This is necessary for the analysis-logs page to list and create download URLs.
    match /pose_analysis_results/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Write access should ideally be handled by a secure backend/server function,
      // but if the Python service runs with user credentials, it might be needed.
      // For now, read-only from the client is sufficient and more secure.
    }
  }
}
