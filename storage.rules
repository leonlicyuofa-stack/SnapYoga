
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Default deny all access to prevent unintended access.
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Allow authenticated users to write to their own video folder.
    // The path is /user-videos/{userId}/{videoId}
    // This rule ensures that a user can only upload to their own directory.
    match /user-videos/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
      // Allow general read access for displaying videos in the app.
      // This can be tightened later if needed (e.g., only logged-in users).
      allow read; 
    }
  }
}
